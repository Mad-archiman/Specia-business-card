{
  "framework": null,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Feature-Policy",
          "value": "camera *; xr-spatial-tracking *;"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=*, xr-spatial-tracking=*"
        }
      ]
    }
  ]
}
